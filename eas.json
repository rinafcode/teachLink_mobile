{
  "cli": {
    "version": ">= 3.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "cache": {
        "key": "development-cache",
        "paths": ["node_modules", ".expo", "android/app/build", "ios/build"]
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease",
        "cache": {
          "key": "android-preview-cache"
        }
      },
      "ios": {
        "cache": {
          "key": "ios-preview-cache"
        }
      },
      "channel": "preview",
      "cache": {
        "key": "preview-cache",
        "paths": ["node_modules", ".expo"]
      },
      "env": {
        "NODE_ENV": "production"
      }
    },
    "production": {
      "ios": {
        "autoIncrement": true,
        "buildConfiguration": "Release",
        "xcodeVersion": "latest",
        "cache": {
          "key": "ios-production-cache",
          "paths": ["ios/Pods", "ios/build"]
        },
        "env": {
          "SWIFT_OPTIMIZATION_LEVEL": "-O",
          "GCC_OPTIMIZATION_LEVEL": "3",
          "LLVM_LTO": "YES",
          "ENABLE_BITCODE": "YES",
          "DEAD_CODE_STRIPPING": "YES",
          "STRIP_INSTALLED_PRODUCT": "YES",
          "STRIP_STYLE": "all",
          "DEPLOYMENT_POSTPROCESSING": "YES",
          "SEPARATE_STRIP": "YES",
          "GCC_GENERATE_DEBUGGING_SYMBOLS": "NO",
          "DEBUG_INFORMATION_FORMAT": "dwarf-with-dsym",
          "COMPILER_INDEX_STORE_ENABLE": "NO"
        }
      },
      "android": {
        "autoIncrement": true,
        "gradleCommand": ":app:bundleRelease",
        "cache": {
          "key": "android-production-cache",
          "paths": ["android/.gradle", "android/app/build"]
        }
      },
      "channel": "production",
      "cache": {
        "key": "production-cache-v1",
        "paths": ["node_modules", ".expo", ".metro-cache"],
        "cacheDefaultPaths": true
      },
      "env": {
        "NODE_ENV": "production"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "your-apple-id@example.com",
        "ascAppId": "your-app-store-connect-app-id",
        "appleTeamId": "your-apple-team-id"
      },
      "android": {
        "serviceAccountKeyPath": "./android-service-account-key.json",
        "track": "production"
      }
    }
  }
}
