# Navigate to your project
cd /path/to/teachLink_mobile

# Accept our version of package.json (already correct on your branch)
git checkout --ours package-lock.json

# Delete the conflicted lock file
rm package-lock.json

# Regenerate it fresh from package.json
npm install

# Stage the regenerated lock file
git add package-lock.json

# Mark the conflict resolved and continue the merge/rebase
git commit
